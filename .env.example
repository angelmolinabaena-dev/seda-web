# ──────────────────────────────────────────────────────────────────
# SEDA Private Homes — environment variables
# Copy this to `.env.local` for local development. Production values
# live in Vercel (`vercel env pull` to sync them down).
# ──────────────────────────────────────────────────────────────────

# Resend API key for transactional emails (contact form).
# Without this, /api/contact runs in mock mode (200 OK, payload logged).
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=

# Destination address for contact form submissions.
# Optional — defaults to info@sedaprivatehomes.com if not set.
SEDA_CONTACT_TO=info@sedaprivatehomes.com
